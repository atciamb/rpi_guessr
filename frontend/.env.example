# Local development - leave empty to use relative paths with Vite proxy
VITE_API_URL=

# Google OAuth Client ID (leave empty to disable auth for local dev)
VITE_GOOGLE_CLIENT_ID=

# Production (set in Vercel environment variables)
# VITE_API_URL=https://api-rpi.neelema.net
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
