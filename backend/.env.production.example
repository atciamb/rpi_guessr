# RPI Guessr Backend - Production Environment Variables
# Copy this to /opt/rpi-guessr/.env on the production server

# PostgreSQL Database
DATABASE_URL=postgres://rpi_guessr:YOUR_DB_PASSWORD@localhost:5432/rpi_guessr?sslmode=require

# AWS S3 Configuration
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Leave empty for standard AWS S3
# AWS_ENDPOINT_URL=
# S3_PUBLIC_ENDPOINT=

# Server
PORT=8080

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ALLOWED_DOMAIN=yourdomain.com
