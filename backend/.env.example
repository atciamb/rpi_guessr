# RPI Guessr Backend - Local Development (without Docker)
# Copy this to .env and modify as needed

# PostgreSQL Database (use port 5433 if running via docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/rpi_guessr?sslmode=disable

# MinIO (local S3-compatible storage)
S3_BUCKET=photos
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Server
PORT=8080

# Google OAuth (leave empty to disable auth for local dev)
GOOGLE_CLIENT_ID=
ALLOWED_DOMAIN=
